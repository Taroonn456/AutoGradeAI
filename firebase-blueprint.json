{
  "entities": {
    "FacultyProfile": {
      "title": "Faculty Profile",
      "description": "Stores profile information for faculty members.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the faculty member." },
        "email": { "type": "string", "format": "email", "description": "The faculty member's email address." },
        "displayName": { "type": "string", "description": "The faculty member's display name." },
        "role": { "type": "string", "enum": ["faculty", "admin"], "description": "The user's role." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "email", "role"]
    },
    "Evaluation": {
      "title": "Evaluation",
      "description": "Stores the results of an exam evaluation.",
      "type": "object",
      "properties": {
        "facultyId": { "type": "string", "description": "The UID of the faculty who performed the evaluation." },
        "question": { "type": "string", "description": "The exam question." },
        "totalMarks": { "type": "number", "description": "The maximum possible marks." },
        "rubric": { "type": "string", "description": "The rubric used for grading." },
        "modelAnswer": { "type": "string", "description": "The ideal answer." },
        "studentAnswer": { "type": "string", "description": "The student's response." },
        "result": { "type": "object", "description": "The structured evaluation result from Gemini." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the evaluation was performed." }
      },
      "required": ["facultyId", "question", "totalMarks", "result", "createdAt"]
    }
  },
  "firestore": {
    "/faculty_profiles/{uid}": {
      "schema": "FacultyProfile",
      "description": "Collection of faculty profiles."
    },
    "/evaluations/{evaluationId}": {
      "schema": "Evaluation",
      "description": "Collection of graded evaluations."
    }
  }
}
